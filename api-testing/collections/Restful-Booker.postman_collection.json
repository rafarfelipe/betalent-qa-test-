  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Get Auth Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response should have token', function() {",
                  "    pm.expect(pm.response.json()).to.have.property('token');",
                  "});",
                  "",
                  "pm.test('Token should not be empty', function() {",
                  "    var token = pm.response.json().token;",
                  "    pm.expect(token).to.be.a('string').and.have.length.above(0);",
                  "});",
                  "",
                  "// Save token for use in other requests",
                  "pm.environment.set('auth_token', pm.response.json().token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"admin\",\n    \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth",
              "host": ["{{base_url}}"],
              "path": ["auth"]
            }
          }
        }
      ]
    },
    {
      "name": "Booking - CRUD Operations",
      "item": [
        {
          "name": "Create Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response should have bookingid', function() {",
                  "    pm.expect(pm.response.json()).to.have.property('bookingid');",
                  "    pm.expect(pm.response.json()).to.have.nested.property('booking.firstname');",
                  "});",
                  "",
                  "pm.test('First name should be John', function() {",
                  "    var firstName = pm.response.json().booking.firstname;",
                  "    pm.expect(firstName).to.equal('John');",
                  "});",
                  "",
                  "// Save booking ID for later use",
                  "pm.environment.set('booking_id', pm.response.json().bookingid);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
